DATABASE_URL=postgresql://user:password@host:port/database
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# OAuth Providers (optional — app works without these, users can sign up with email/password)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Email (optional — only needed for transactional emails, not for auth)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=NextNest <noreply@yourdomain.com>

# Cron / AI (optional)
CRON_SECRET=generate-a-random-secret-for-cron-endpoint
OPENAI_API_KEY=sk-your-openai-key-here
